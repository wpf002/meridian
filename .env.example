# Meridian Environment Configuration
MERIDIAN_ENV=development
DB_PATH=./db/meridian.db
LOG_LEVEL=INFO
LOG_PATH=./logs
DATA_INPUT_PATH=./data/inputs
DATA_PROCESSED_PATH=./data/processed

# Anthropic (for Research Copilot and conversational interface)
ANTHROPIC_API_KEY=your_key_here

# ACS Scoring Weights (must sum to 1.0 across positive components)
WEIGHT_MACRO=0.35
WEIGHT_TACTICAL=0.30
WEIGHT_SENTIMENT=0.20
WEIGHT_STRUCTURAL_RISK=0.15

# Priority Thresholds
THRESHOLD_TIER_1=0.75
THRESHOLD_TIER_2=0.45

# Portfolio Sleeve Targets (as decimal)
SLEEVE_CORE=0.40
SLEEVE_GROWTH=0.30
SLEEVE_DEFENSIVE=0.20
SLEEVE_TACTICAL=0.10
